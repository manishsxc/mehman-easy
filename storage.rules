rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Property images: publicly readable, but only a signed-in owner can
    // upload into their own uid-scoped folder, capped at 8MB per file.
    match /properties/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
